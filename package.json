{
  "name": "jls-api-con",
  "version": "0.1.0",
  "description": "OpenAPI 3.1 wire contract for the Jules API REST v1alpha",
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "scripts": {
    "fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "bundle": "REDOCLY_SUPPRESS_UPDATE_NOTICE=true redocly bundle spec/openapi.yaml -o dist/openapi.json",
    "test": "bun test",
    "check": "biome check . && bun run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@redocly/cli": "^1.34.0",
    "@types/bun": "^1.3.14",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  }
}
